# ============================================================
# Expense Tracker MCP Server — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Async URL (used by the application)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/expense_tracker

# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/expense_tracker

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Application ──────────────────────────────────────────────
APP_NAME=ExpenseTrackerMCP
APP_VERSION=1.0.0
DEBUG=false

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Reports ──────────────────────────────────────────────────
REPORTS_DIR=./reports

# ── Currency ─────────────────────────────────────────────────
DEFAULT_CURRENCY=INR

# ── Backup ───────────────────────────────────────────────────
BACKUP_DIR=./backups
